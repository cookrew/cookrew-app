{
  "name": "cookrew",
  "version": "0.1.0",
  "description": "Cookrew — an open-source spatial canvas for AI agents, inspired by Maestri. Terminals, notes, portals and physics cables on an infinite canvas, orchestrated through a Unix-socket CLI.",
  "main": "out/main/index.js",
  "type": "module",
  "license": "MIT",
  "bin": {
    "cookrew": "./cli/cookrew.mjs"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w node-pty",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.3.0",
    "marked": "^15.0.0",
    "node-pty": "^1.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.2.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
